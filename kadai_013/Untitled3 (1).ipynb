      "source": [
        "# 消費税を計算して税込金額を返す関数\n",
        "def calc_tax(price, tax_rate):\n",
        "    # 税率はパーセント（例：10）で受け取り、小数に直して計算\n",
        "    tax = price * (tax_rate / 100)\n",
        "    total = price + tax\n",
        "    return total  # 戻り値として返す\n",
        "\n",
        "# 関数を使って計算\n",
        "result = calc_tax(110, 10)  # 第1引数：110円の商品、第2引数：10%の消費税\n",
        "print(result)  # 結果を表示"
      ],
